# 应用环境
NODE_ENV=development

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_NAME=career_assessment
DB_USER=root
DB_PASSWORD=password

# 管理员密码
ADMIN_PASSWORD=admin-password-placeholder

# Session密钥（生产环境请修改）
SESSION_SECRET=your-secret-key-here-change-in-production

# 前端地址（用于CORS）
FRONTEND_URL=http://localhost:8080